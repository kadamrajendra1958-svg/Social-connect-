{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "handle": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "followers": { "type": "number" },
        "following": { "type": "number" },
        "coverImage": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "handle", "followers", "following", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "User post containing text and optional image",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "sharesCount": { "type": "number" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["authorId", "content", "likesCount", "commentsCount", "sharesCount", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "Like interaction on a post",
      "type": "object",
      "properties": {
        "createdAt": { "type": "timestamp" }
      },
      "required": ["createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["authorId", "content", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "Follow relationship",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "actorId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow", "mention"] },
        "postId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["actorId", "type", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores posts"
    },
    "posts/{postId}/likes/{userId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Tracks who liked a post"
    },
    "posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on a post"
    },
    "follows/{followId}": {
      "schema": { "$ref": "#/entities/Follow" },
      "description": "Tracks follow relationships"
    },
    "users/{userId}/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications"
    }
  }
}
